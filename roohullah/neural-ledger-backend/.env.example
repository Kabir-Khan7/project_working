# ── Copy this file to .env and fill in your values ───────────
# Never commit .env to git!

# App
APP_NAME=Neural Ledger
DEBUG=True
ENVIRONMENT=development

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/neural_ledger

# JWT  (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=replace-with-a-very-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AES-256 (32-byte hex string)
MASTER_ENCRYPTION_KEY=replace-with-32-byte-random-hex-string

# CORS (comma-separated)
ALLOWED_ORIGINS=["http://localhost:3000"]
